# ═══════════════════════════════════════════════════════════════════════════════
# UNIAIVERSE WEBSITE - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and configure your environment variables
# NEVER commit .env.local to version control!

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (XAMPP MySQL)
# ───────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=uniaiverse

# ───────────────────────────────────────────────────────────────────────────────
# APPLICATION CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# Base URL for the website (used for SEO, redirects, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Base URL (if using separate backend)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ───────────────────────────────────────────────────────────────────────────────
# ADMIN PANEL CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# Admin authentication (hardcoded for now, should move to database)
ADMIN_EMAIL=admin@uniaiverse.com
ADMIN_PASSWORD=admin@123

# ───────────────────────────────────────────────────────────────────────────────
# CALENDLY INTEGRATION (Optional - for booking features)
# ───────────────────────────────────────────────────────────────────────────────
# Get your API key from: https://calendly.com/integrations/api_webhooks
CALENDLY_API_KEY=

# Your Calendly username or organization
CALENDLY_USER=

# ───────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (Optional - for contact form notifications)
# ───────────────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@uniaiverse.com
SMTP_FROM_NAME=uniAiverse

# Email recipient for contact form submissions
CONTACT_EMAIL=info@uniaiverse.com

# ───────────────────────────────────────────────────────────────────────────────
# SECURITY & SESSION (Optional but recommended for production)
# ───────────────────────────────────────────────────────────────────────────────
# Generate using: openssl rand -base64 32
# SESSION_SECRET=

# ───────────────────────────────────────────────────────────────────────────────
# FILE UPLOAD (Optional - if implementing file uploads)
# ───────────────────────────────────────────────────────────────────────────────
# Maximum file upload size in MB
MAX_FILE_SIZE=10

# Upload directory path (relative to project root)
UPLOAD_DIR=public/uploads

# ───────────────────────────────────────────────────────────────────────────────
# ANALYTICS (Optional - for tracking)
# ───────────────────────────────────────────────────────────────────────────────
# Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID=

# ───────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS (Optional - for enabling/disabling features)
# ───────────────────────────────────────────────────────────────────────────────
ENABLE_BLOG=true
ENABLE_TESTIMONIALS=true
ENABLE_CONTACT_FORM=true
ENABLE_CALENDLY_BOOKING=false

# ───────────────────────────────────────────────────────────────────────────────
# PRODUCTION SETTINGS (Only for production deployment)
# ───────────────────────────────────────────────────────────────────────────────
# Set to 'production' when deploying
NODE_ENV=development

# Disable source maps in production for security
# GENERATE_SOURCEMAP=false
